# ---- Database (PostgreSQL) ----
# ตั้ง DATABASE_URL เต็มๆ ก็ได้ หรือแยกเป็นราย field ด้านล่าง
# ถ้าไม่ตั้งอะไรเลย backend จะใช้ค่า default: localhost/postgres/iconfirm:5432
# DATABASE_URL=host=localhost user=postgres password=Kobelco.com dbname=iconfirm port=5432 sslmode=disable
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=Kobelco.com
DB_NAME=iconfirm
DB_PORT=5432
DB_SSLMODE=disable

# ---- Server ----
PORT=8080

# ---- Auth ----
# ควรตั้งค่า secret ของตัวเองใน production
JWT_SECRET=iconfirm-secret-key

# ---- CORS ----
# รายชื่อ origin ของ frontend ที่อนุญาตให้เรียก API ได้ คั่นด้วยจุลภาค
# ถ้าไม่ตั้งจะ fallback เป็น origin dev บนเครื่อง (localhost:9004 / :5173) เท่านั้น
# ALLOWED_ORIGINS=https://iconfirm.kobelco.internal,https://iconfirm-staging.kobelco.internal
